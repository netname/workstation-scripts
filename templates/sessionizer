#!/usr/bin/env bash
# sessionizer — tmux project switcher
# Copy this file to ~/dotfiles/scripts/sessionizer in your PRIVATE dotfiles repo.
# The bootstrap script symlinks it to ~/.local/bin/sessionizer.
#
# Bind it to a key in tmux.conf:
#   bind-key -n C-f display-popup -E "~/.local/bin/sessionizer"
#
# How it works:
#   1. Finds all directories one level deep under each search path
#   2. Presents them in fzf for fuzzy selection
#   3. Creates a new tmux session named after the selected directory (if one
#      doesn't already exist), then switches to it
#
# To add more search paths, append them to the SEARCH_PATHS array below.
# See docs/3-Terminal.md for the full sessionizer workflow.

set -euo pipefail

# Popup shells do not always load the Nix profile. Source it so fzf is available.
. "$HOME/.nix-profile/etc/profile.d/nix.sh" 2>/dev/null || true
export PATH="$HOME/.local/bin:$HOME/.nix-profile/bin:$PATH"

# ── Search paths ──────────────────────────────────────────────────────────────
# Directories listed here are scanned one level deep for project folders.
SEARCH_PATHS=(
    "$HOME/projects"
    "$HOME/dotfiles"
)

# Build the find command dynamically from the search paths array.
find_args=()
for path in "${SEARCH_PATHS[@]}"; do
    if [ -d "$path" ]; then
        find_args+=("$path")
    fi
done

if [ ${#find_args[@]} -eq 0 ]; then
    echo "sessionizer: no search paths found" >&2
    exit 1
fi

# ── Selection ─────────────────────────────────────────────────────────────────
selected=$( \
    find "${find_args[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null \
    | sort \
    | fzf --prompt="project: " --height=40% --reverse \
    || true \
)

if [ -z "$selected" ]; then
    exit 0
fi

# ── Session name ──────────────────────────────────────────────────────────────
# tmux session names cannot contain spaces or dots — replace them with underscores.
selected_name=$(basename "$selected" | tr ' .' '_')

# ── Switch or create ──────────────────────────────────────────────────────────
if ! tmux has-session -t "$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

if [ -n "${TMUX:-}" ]; then
    # Already inside tmux — switch client to the target session.
    tmux switch-client -t "$selected_name"
else
    # Outside tmux — attach to the target session.
    tmux attach-session -t "$selected_name"
fi
